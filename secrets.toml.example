# Streamlit Cloud Secrets Template
# Copy this content to your Streamlit Cloud app's Secrets section
# Go to: https://share.streamlit.io → Your App → Settings → Secrets

# OpenAI API Key (required for AI features)
OPENAI_API_KEY = "your-openai-api-key-here"

# Optional: Azure OpenAI Configuration (if using Azure instead of OpenAI)
# AZURE_OPENAI_ENDPOINT = "https://your-resource.openai.azure.com/"
# AZURE_OPENAI_API_KEY = "your-azure-key-here"
# AZURE_OPENAI_DEPLOYMENT = "gpt-4o"
